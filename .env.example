# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter AI (required for Website Builder and AI features)
OPENROUTER_API_KEY=sk-or-...

# Twilio SMS (optional — SMS notifications)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+18015550100
NOTIFY_PHONE_NUMBER=+18015550100

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# App URLs
NEXT_PUBLIC_BACKEND_URL=https://app.useezly.com
NEXT_PUBLIC_SITE_URL=https://app.useezly.com

# Prolink Sales CRM
# RESEND_API_KEY is shared with the /api/contact route.
# CRM_FROM_EMAIL must use a domain verified in Resend before deliveries
# outside your test inbox will succeed.
RESEND_API_KEY=re_...
CRM_FROM_EMAIL=Brian Nelsen <Brian@useezly.com>
# Optional: where recipient replies should land. If unset, replies go to
# the From address above. Set this if you want replies routed to a shared
# inbox or a different person from the From identity.
# CRM_REPLY_TO=sales@useezly.com

# SignWell e-signature (scaffolded — keep disabled until ready to activate)
SIGNWELL_ENABLED=false
SIGNWELL_API_KEY=
SIGNWELL_WEBHOOK_SECRET=
NEXT_PUBLIC_SIGNWELL_ENABLED=false

# Stripe billing
# Server-side secret key (sk_test_... in test mode, sk_live_... in production)
STRIPE_SECRET_KEY=sk_test_...
# Client-side publishable key — exposed to the browser for Stripe.js / Elements
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook signing secret from the Stripe dashboard (whsec_...)
# Used by /api/stripe/webhook to verify event authenticity
STRIPE_WEBHOOK_SECRET=whsec_...
# Recurring price IDs for the seats-based subscription
# Base plan: $49/mo (owner seat included)
STRIPE_BASE_PRICE_ID=price_...
# Per additional seat: $15/mo
STRIPE_SEAT_PRICE_ID=price_...
