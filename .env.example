# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter AI (required for Website Builder and AI features)
OPENROUTER_API_KEY=sk-or-...

# Twilio SMS (optional — SMS notifications)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+18015550100
NOTIFY_PHONE_NUMBER=+18015550100

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# App URLs
NEXT_PUBLIC_BACKEND_URL=https://app.useezly.com
NEXT_PUBLIC_SITE_URL=https://app.useezly.com

# SignWell e-signature (scaffolded — keep disabled until ready to activate)
SIGNWELL_ENABLED=false
SIGNWELL_API_KEY=
SIGNWELL_WEBHOOK_SECRET=
NEXT_PUBLIC_SIGNWELL_ENABLED=false

# Stripe Connect (Express) — contractor payments & payouts
# 1. Get keys from https://dashboard.stripe.com/apikeys
# 2. Enable Connect at https://dashboard.stripe.com/connect/overview
# 3. Register two webhook endpoints (both pointing at /api/stripe/webhook):
#    a. Standard endpoint listening for: account.updated -> STRIPE_WEBHOOK_SECRET
#    b. Connect endpoint listening for: checkout.session.completed,
#       charge.refunded -> STRIPE_CONNECT_WEBHOOK_SECRET
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...
# Platform fee in basis points (200 = 2.00%)
PLATFORM_FEE_BPS=200
# Trial length for subscription Checkout sessions (days)
STRIPE_TRIAL_DAYS=14
# Webhook events to enable on the PLATFORM endpoint (in addition to
# account.updated for Connect): customer.subscription.created,
# customer.subscription.updated, customer.subscription.deleted,
# checkout.session.completed, invoice.payment_failed
#
# In Stripe Dashboard, create three Prices with these lookup_keys for
# subscription plans: starter_monthly ($29), pro_monthly ($49),
# business_monthly ($149). The app resolves them at runtime.
